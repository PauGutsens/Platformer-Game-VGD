<?xml version="1.0"?>
<config>
	<engine>
		<title>My platformer game</title>
		<maxFrameDuration value="16" />
	</engine>
	<render>
		<vsync value="false" />
	</render>
	<window>
		<resolution width="1280" height="720" scale="1" />
		<fullscreen value="false" />
		<borderless value="false" />
		<resizable value="false" />
		<fullscreen_window value="false" />
	</window>
	<scene>
		<map path="Assets/Maps/" name="MapTemplate.tmx" />
		<entities>
			<player x="70" y="670" w="32" h="32" texture="Assets/Textures/player/Idle.png">
				<animations>
					<walk loop="true" speed="0.5">
						<frame x="0" y="0" w="32" h="32" />
						<frame x="32" y="0" w="32" h="32" />
						<frame x="64" y="0" w="32" h="32" />
						<frame x="96" y="0" w="32" h="32" />
						<frame x="128" y="0" w="32" h="32" />
						<frame x="160" y="0" w="32" h="32" />
					</walk>
					<idle loop="false" speed="0">
						<frame x="0" y="0" w="32" h="32" />
					</idle>
				</animations>
			</player>
			<enemies>
				<enemy name="badguy" x="90" y="660" w="32" h="32" texture="Assets/Textures/enemy/walking_enemy.png" gravity="true">
					<animations>
						<walk loop="true" speed="0.25">
							<frame x="0" y="0" w="32" h="32" />
							<frame x="32" y="0" w="32" h="32" />
							<frame x="64" y="0" w="32" h="32" />
							<frame x="96" y="0" w="32" h="32" />
							<frame x="128" y="0" w="32" h="32" />
							<frame x="160" y="0" w="32" h="32" />
						</walk>
					</animations>
				</enemy>
				<enemy2 name="badguy" x="90" y="400" w="32" h="32" texture="Assets/Textures/enemy/flying_enemy.png" gravity="true">
					<animations>
						<fly loop="true" speed="0.25">
							<frame x="0" y="0" w="32" h="32" />
							<frame x="32" y="0" w="32" h="32" />
							<frame x="64" y="0" w="32" h="32" />
							<frame x="96" y="0" w="32" h="32" />
							<frame x="128" y="0" w="32" h="32" />
							<frame x="160" y="0" w="32" h="32" />
						</fly>
					</animations>
				</enemy2>
			</enemies>
		</entities>
		<sounds>
			
		</sounds>
	</scene>
</config>
